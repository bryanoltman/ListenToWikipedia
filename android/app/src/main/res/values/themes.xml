<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ListenToWikipedia" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_background</item>
    </style>

    <!-- Splash screen: solid dark background, no visible icon. -->
    <style name="Theme.ListenToWikipedia.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.ListenToWikipedia</item>
    </style>

    <color name="dark_background">#1B2024</color>
</resources>
